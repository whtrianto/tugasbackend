# ============ Supabase (untuk backend API) ============
# Ambil dari: Supabase Dashboard → Project Settings → API
# WAJIB — dipakai di lib/supabase.ts (getSupabaseServer)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# WAJIB — dipakai di lib/supabase.ts (jangan commit; hanya di .env.local / Vercel)
SUPABASE_SERVICE_ROLE_KEY=your-secret-service-role-key
# Opsional — Anon Key (Legacy); untuk client-side Supabase kalau dipakai
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-dashboard

# ============ App (opsional) ============
# Untuk production di Vercel: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
